{
  "manifest_version": 3,
  "name": "htmlGenius",
  "version": "0.4.0",
  "description": "HTML 批注 + 编辑 + 回灌 + 多人协同",
  "permissions": ["activeTab", "sidePanel", "storage"],
  "host_permissions": ["https://YOUR_BACKEND_HOST/*"],
  "side_panel": { "default_path": "sidepanel.html" },
  "background": { "service_worker": "background.js" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_title": "htmlGenius", "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" } },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["vendor/purify.min.js", "text-quote.js", "remote-store.js", "sync.js", "storage.js", "buildprompt.js", "content-script.js"],
    "run_at": "document_idle"
  }]
}
