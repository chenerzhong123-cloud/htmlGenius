{
  "name": "@htmlgenius/bridge",
  "version": "0.9.2",
  "description": "HTML Genius Local Bridge — Chrome Native Messaging host that hands a Change Contract to the user's locally signed-in AI agent (Claude Code CLI / Codex App Server / GitHub Copilot via @github/copilot-sdk). One provider-neutral host; writes only candidate/plan files, never the source HTML.",
  "author": "chenerzhong123-cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenerzhong123-cloud/htmlGenius.git",
    "directory": "bridge"
  },
  "homepage": "https://github.com/chenerzhong123-cloud/htmlGenius/tree/main/bridge#readme",
  "bugs": {
    "url": "https://github.com/chenerzhong123-cloud/htmlGenius/issues"
  },
  "type": "module",
  "engines": { "node": "^20.0.0 || >=22.0.0" },
  "bin": {
    "htmlgenius-bridge-host": "host.mjs",
    "htmlgenius-bridge": "bin/htmlgenius-bridge.mjs"
  },
  "files": [
    "bin/",
    "*.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "verify:bootstrap": "node verify/bootstrap-verify.mjs",
    "verify:providers": "node verify/provider-certify.mjs --all",
    "verify": "npm test && npm run verify:bootstrap && npm run verify:providers",
    "smoke:local": "node verify/real-smoke.mjs",
    "smoke:provider": "node verify/real-smoke.mjs --provider",
    "install:macos": "node install-macos.mjs"
  },
  "dependencies": {
    "@github/copilot-sdk": "1.0.7"
  },
  "license": "MIT"
}
