#!/bin/sh
# test/fake-claude-bin/claude — 假 Claude Code CLI(供 claude-cli.mjs 的真实 spawn 测试)。
# 测试把本目录临时加到 PATH 最前,spawn("claude", ...) 就会命中本脚本(验证真实子进程路径,
# 包括 argv 注入安全:注入串只能作为一个 argv 元素出现,绝不会被 shell 解释)。
#
# 行为由文件控制(sanitizedEnv 只透传 PATH/HOME/TMPDIR 等白名单,不能靠自定义 env):
#   mode 文件:$TMPDIR/fake-claude.mode.$PPID(PPID=测试进程 pid,天然隔离并行测试文件)
#   argv 日志:$TMPDIR/fake-claude.argv.$PPID —— NUL 分隔各 argv 元素,调用之间以 "END\0" 结尾。
#   (用 NUL 而非换行:注入测试的 prompt 含真实换行,换行分隔会撕裂记录;NUL 不会出现在 argv 里)
# mode: ok(默认) | auth-fail | bad-json | no-uuid | fail | slow
base="${TMPDIR:-/tmp}"
cfg="$base/fake-claude.mode.$PPID"
log="$base/fake-claude.argv.$PPID"
{
  for a in "$@"; do printf '%s\000' "$a"; done
  printf 'END\000'
} >> "$log" 2>/dev/null
mode="$(cat "$cfg" 2>/dev/null || echo ok)"
case "$1" in
  auth)
    if [ "$mode" = "auth-fail" ]; then echo "claude: not logged in" >&2; exit 1; fi
    echo '{"loggedIn":true}'
    exit 0
    ;;
esac
# claude -p ... 路径
case "$mode" in
  bad-json) echo "this is definitely not json"; exit 0 ;;
  no-uuid)  echo '{"type":"result","subtype":"success","session_id":"not-a-uuid"}'; exit 0 ;;
  fail)     echo "claude: simulated failure" >&2; exit 3 ;;
  slow)     sleep 30; exit 0 ;;
esac
echo '{"type":"result","subtype":"success","is_error":false,"num_turns":1,"session_id":"11111111-2222-3333-4444-555555555555","result":"acknowledged"}'
exit 0
